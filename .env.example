# GCP Configuration
GCP_PROJECT=your-project-id
GCP_REGION=us-central1

# NewsAPI Configuration
NEWS_API_KEY=your-newsapi-key-here

# Alternative collector APIs
SERPAPI_KEY=your-serpapi-key-here
GNEWS_KEY=your-gnews-key-here

# BigQuery Configuration
BIGQUERY_DATASET=k12_ai_dataset

# Root classifier default
BIGQUERY_TABLE=classified_articles
MANUAL_REVIEW_THRESHOLD=8
TRIAGE_PROMPT_CHAR_LIMIT=8000
EXTRACTION_PROMPT_CHAR_LIMIT=8000
ENABLE_LOCAL_TRIAGE_AUDIT=true
LOCAL_TRIAGE_AUDIT_PATH=/tmp/k12_triage_audit.jsonl

# Cloud Run Configuration (optional)
PORT=8080
